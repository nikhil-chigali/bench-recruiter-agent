        <mxCell id="i8boH2LqC3hHRUDyFnox-60" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;glass=0;sketch=1;curveFitting=1;jiggle=2;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Candidate-Job Mapping Logic ‼️&lt;/h1&gt;&lt;p&gt;1. Pre-filters&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;1.1 Applied = False&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;1.2 VISA eligibility matching (if applicable)&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;1.3 Years of Experience (if applicable)&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;1.4 Location Preference (if applicable)&lt;/span&gt;&lt;/p&gt;&lt;p&gt;2. Similarity Search (Candidate&#39;s profile x Job Description)&lt;/p&gt;" vertex="1">
