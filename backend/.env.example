# Backend configuration template — copy to `.env` and fill in. NEVER commit the real .env.
# Read by `callup.config.settings` (pydantic-settings); env names match the field names
# case-insensitively. Fields without a default are REQUIRED: the app fails fast at startup
# if they're missing. In production these are set as Railway service variables, not a file
# (see docs/deployment.md).

# ── Required ───────────────────────────────────────────────────────────────────────

# Postgres (Supabase). Use the Direct or Session pooler connection (port 5432) with the
# asyncpg driver — NOT the Transaction pooler (6543), which breaks prepared statements +
# Alembic. Do NOT put ?sslmode=... in the URL (asyncpg rejects it; use DATABASE_SSL).
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Anthropic API key (secret). Required at boot even before LLM features are wired up.
ANTHROPIC_API_KEY=sk-ant-...

# ── Required for auth + team management ──────────────────────────────────────────────

# Supabase project URL. Used for JWT verification (JWKS endpoint) and the Auth Admin client.
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service-role key (secret). Powers member/org auth-account deletion (slice 3).
# Backend only — never expose to the frontend / never put in a VITE_* var.
SUPABASE_SERVICE_KEY=

# ── Optional (defaults shown) ────────────────────────────────────────────────────────

# "development" or "production". Production disables the dev-only uvicorn reload.
ENVIRONMENT=development

# DB password supplied out-of-URL (secret) so special characters don't need URL-encoding;
# overrides any password embedded in DATABASE_URL. Leave blank if it's already in the URL.
DATABASE_PASSWORD=

# Supabase requires SSL; set false only for a local non-SSL Postgres.
DATABASE_SSL=true

# CORS: the SPA origin allowed to call this API. Set to the deployed frontend URL in prod.
FRONTEND_ORIGIN=http://localhost:5173

# LLM / embeddings (defaults are fine until those features land).
LLM_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=stub-embedding-v0
EMBEDDING_DIM=1536

# Supabase Storage bucket for generated .docx artifacts.
STORAGE_BUCKET=candidate-files

# Supabase JWT audience claim (Supabase default).
SUPABASE_JWT_AUD=authenticated

# Matching tunables.
MATCH_FRESHNESS_DAYS=30
MATCH_TOP_K=25

# Product gate: keep public email send off unless explicitly enabled.
OUTREACH_SEND_ENABLED=false
