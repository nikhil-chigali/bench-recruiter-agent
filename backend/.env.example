# Copy to .env and fill in. Loaded by callup.config.Settings.

# Supabase Postgres via asyncpg. Use the Direct or Session pooler connection (port 5432),
# NOT the Transaction pooler (6543). Strip any ?sslmode=... — set DATABASE_SSL instead.
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres
DATABASE_SSL=true

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6

# Supabase project URL — required for auth (JWKS verification of bearer tokens).
SUPABASE_URL=https://<project-ref>.supabase.co
# JWT audience claim Supabase issues (leave default unless you changed it).
SUPABASE_JWT_AUD=authenticated
# CORS: the SPA origin allowed to call this API (dev Vite server default below).
FRONTEND_ORIGIN=http://localhost:5173

# Object storage (Supabase) — required before resume generation (Phase 4)
# (SUPABASE_URL is set above)
# SUPABASE_SERVICE_KEY=...
# STORAGE_BUCKET=resumes

# ENVIRONMENT=development
# MATCH_FRESHNESS_DAYS=30
# OUTREACH_SEND_ENABLED=false
