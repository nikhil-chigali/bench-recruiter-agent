# Copy to .env and fill in. Loaded by callup.config.Settings.

# Direct/session Postgres connection (asyncpg) — NOT the Supabase transaction pooler.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6

# Object storage (Supabase) — required before resume generation (Phase 4)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=...
# STORAGE_BUCKET=resumes

# ENVIRONMENT=development
# MATCH_FRESHNESS_DAYS=30
# OUTREACH_SEND_ENABLED=false
